# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_URL=http://dev.local
APP_NAME="ReviewReplyPro"

# ── Datenbank ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=devproject
DB_USER=devuser
DB_PASS=           # Passwörter mit Sonderzeichen (#, !, etc.) in Anführungszeichen: DB_PASS="geheim#123"

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECURE_COOKIE=false   # true nur auf HTTPS-Produktivserver

# ── Stripe ───────────────────────────────────────────────────────────────────
# Test-Keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_DEIN_KEY_HIER_EINTRAGEN
STRIPE_PUBLISHABLE_KEY=pk_test_DEIN_KEY_HIER_EINTRAGEN
STRIPE_WEBHOOK_SECRET=whsec_DEIN_SECRET_HIER_EINTRAGEN
BILLING_ENABLED=false

# ── Admin ─────────────────────────────────────────────────────────────────────
# Kommagetrennte E-Mail-Adressen, die /admin auch ohne owner-Rolle sehen dürfen
ADMIN_EMAIL_ALLOWLIST=

# ── Recht / DSGVO ─────────────────────────────────────────────────────────────
# false = Platzhalter anzeigen, true = echte Texte eingeblendet
LEGAL_MODE=false
